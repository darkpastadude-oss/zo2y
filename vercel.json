{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "max-image-preview:none, noimageindex"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self' https:; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https:; media-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' data: https:; connect-src 'self' https: wss:; frame-src https:; worker-src 'self' blob:; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth",
      "destination": "/api/support-handler?path=auth"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/support-handler?path=auth/:path*"
    },
    {
      "source": "/api/music",
      "destination": "/api/music-handler"
    },
    {
      "source": "/api/music/:path*",
      "destination": "/api/music-handler?path=:path*"
    },
    {
      "source": "/api/igdb",
      "destination": "/api/igdb-handler"
    },
    {
      "source": "/api/igdb/:path*",
      "destination": "/api/igdb-handler?path=:path*"
    },
    {
      "source": "/api/tmdb",
      "destination": "/api/tmdb-handler"
    },
    {
      "source": "/api/tmdb/:path*",
      "destination": "/api/tmdb-handler?path=:path*"
    },
    {
      "source": "/api/books",
      "destination": "/api/books-handler"
    },
    {
      "source": "/api/books/:path*",
      "destination": "/api/books-handler?path=:path*"
    },
    {
      "source": "/api/openlibrary",
      "destination": "/api/openlibrary-handler"
    },
    {
      "source": "/api/openlibrary/:path*",
      "destination": "/api/openlibrary-handler?path=:path*"
    },
    {
      "source": "/api/sportsdb",
      "destination": "/api/sportsdb-handler"
    },
    {
      "source": "/api/sportsdb/:path*",
      "destination": "/api/sportsdb-handler?path=:path*"
    },
    {
      "source": "/api/analytics",
      "destination": "/api/analytics-handler"
    },
    {
      "source": "/api/analytics/:path*",
      "destination": "/api/analytics-handler?path=:path*"
    },
    {
      "source": "/api/support",
      "destination": "/api/support-handler"
    },
    {
      "source": "/api/support/:path*",
      "destination": "/api/support-handler?path=:path*"
    },
    {
      "source": "/api/emails",
      "destination": "/api/emails-handler"
    },
    {
      "source": "/api/emails/:path*",
      "destination": "/api/emails-handler?path=:path*"
    }
  ]
}
