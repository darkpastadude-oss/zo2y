{
  "name": "zo2y-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Zo2y restaurant app backend",
  "main": "backend/index.js",
  "scripts": {
    "start": "cd backend && node index.js",
    "dev": "cd backend && nodemon index.js",
    "cf:build": "node scripts/build-cloudflare-pages.mjs",
    "cf:dev": "wrangler pages dev dist",
    "cf:deploy": "npm run cf:build && wrangler pages deploy",
    "import:books": "node scripts/import-books.mjs",
    "import:games:popular": "node scripts/import-popular-games.mjs",
    "import:games:franchises": "node scripts/import-game-franchises.mjs",
    "import:games:mega": "node scripts/import-popular-games.mjs --limit=1500 --max-pages=100 --rawg-max-pages=180 --with-details=false && node scripts/import-game-franchises.mjs --limit=320 --delay=250 --max-pages=18 --rawg-max-pages=28",
    "seed:brands": "node scripts/seed-brands.mjs",
    "import:brands:wikidata": "node scripts/import-brands-wikidata.mjs",
    "backfill:logos": "node scripts/backfill-brand-logos.mjs",
    "upload:logos": "node scripts/upload-brand-logos.mjs",
    "dedupe:brands": "node scripts/dedupe-brands.mjs",
    "smoke": "node scripts/smoke-runner.mjs",
    "smoke:launch": "node scripts/smoke-runner.mjs"
  },
  "keywords": [
    "restaurant",
    "auth",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.86.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkpastadude-oss/zo2y.git"
  },
  "bugs": {
    "url": "https://github.com/darkpastadude-oss/zo2y/issues"
  },
  "homepage": "https://github.com/darkpastadude-oss/zo2y#readme"
}
